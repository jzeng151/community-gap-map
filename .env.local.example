# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-only, never expose to client

# Mapbox — get from mapbox.com > Tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# Upstash Redis — get from upstash.com > Redis > REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here
